n IE 10+.\r\n */\r\n\r\ntemplate {\r\n   display: none;\r\n}\r\n\r\n/**\r\n * Add the correct display in IE 10.\r\n */\r\n\r\n[hidden] {\r\n   display: none;\r\n}\r\n","stylesheets/styles.scss":"@import \"normalize\";\r\n@import \"variables\";\r\n@import \"navigation\";\r\n@import url(\"https://fonts.googleapis.com/css?family=Raleway:300,400,700&display=swap\");\r\n\r\n// Accessorie Styles\r\n.ma {\r\n   margin: auto;\r\n} // Margin Auto\r\n\r\nbody {\r\n   font-family: \"Raleway\", sans-serif, Arial;\r\n   font-size: 10px;\r\n}\r\n","stylesheets/navigation.scss":"header {\r\n   width: 100%;\r\n   height: 95px;\r\n   background: $l-black;\r\n   .logo {\r\n      padding-left: 1.5rem;\r\n   }\r\n   nav {\r\n      max-width: 1040px;\r\n      height: 95px;\r\n      margin: auto;\r\n      display: flex;\r\n      align-items: center;\r\n      .menu-container {\r\n         display: flex;\r\n         justify-content: flex-end;\r\n         align-items: center;\r\n         width: 100%;\r\n         ul.menu:first-child {\r\n            margin-right: 2rem;\r\n         }\r\n         ul.menu {\r\n            @include horizontal-list;\r\n            // @include bor;\r\n            .nav-list:hover {\r\n               filter: contrast(30%);\r\n            }\r\n         }\r\n         .nav-social-icons {\r\n            padding: 0 0.6rem;\r\n            cursor: pointer;\r\n            :hover {\r\n               filter: contrast(30%);\r\n            }\r\n         }\r\n      }\r\n   }\r\n}\r\n\r\n@media only screen and (max-width: 900px) {\r\n   .menu-container {\r\n      flex-direction: column;\r\n      position: absolute;\r\n      top: 5rem;\r\n      background: $l-black;\r\n      ul.menu.nav-menu {\r\n         display: flex;\r\n         flex-direction: column;\r\n         text-align: center;\r\n         width: 100%;\r\n         padding: 0;\r\n         a {\r\n            padding: 0;\r\n         }\r\n         li {\r\n            padding: 1rem 0;\r\n            border-bottom: 0.5px solid 